# CatDB auth database (Postgres) — split values
CATDB_AUTH_HOST=127.0.0.1
CATDB_AUTH_PORT=5432
CATDB_AUTH_USER=postgres
CATDB_AUTH_PASSWORD=
CATDB_AUTH_DATABASE=catdb
CATDB_AUTH_SSL=false

# Optional SSH tunnel
CATDB_AUTH_SSH_HOST=
CATDB_AUTH_SSH_PORT=22
CATDB_AUTH_SSH_USER=
CATDB_AUTH_SSH_PASSWORD=
# CATDB_AUTH_SSH_PRIVATE_KEY=
CATDB_AUTH_SSH_KEEP_ALIVE=true
